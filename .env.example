# Copy this file to .env for local dev. Never commit .env.
# In production (Render, etc.), set these in the hosting provider's dashboard.

NODE_ENV=development

# Email — pickup requests are emailed via Resend (https://resend.com).
# Without RESEND_API_KEY, requests are still saved to the DB but no email is sent.
RESEND_API_KEY=
EMAIL_TO=thelastmilebooks@gmail.com
EMAIL_FROM=pickups@lastmilebooks.com
